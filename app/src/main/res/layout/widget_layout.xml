<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/widget_logo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/img_app_icon"
        android:layout_marginEnd="12dp"
        android:scaleType="fitCenter" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dark Store Hub"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONLINE"
                android:textColor="#10B981"
                android:textSize="8sp"
                android:textStyle="bold"
                android:background="@drawable/widget_status_bg"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:paddingTop="1.5dp"
                android:paddingBottom="1.5dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SECURE DATABASE ACCESS"
            android:textColor="#34D399"
            android:textSize="8sp"
            android:textStyle="bold"
            android:layout_marginTop="1dp" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="5dp"
            android:progressDrawable="@drawable/widget_progress_bar" />

        <TextView
            android:id="@+id/widget_storage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Storage: Real space loading..."
            android:textColor="#9CA3AF"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_packages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to manage deployments"
            android:textColor="#6B7280"
            android:textSize="9sp" />
    </LinearLayout>
</LinearLayout>
